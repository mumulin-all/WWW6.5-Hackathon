# Alcheme Backend Environment Variables

# Server
PORT=30001

# OpenAI API 配置
# API Key（必填，配置后启用 AI 功能）
OPENAI_API_KEY=your_api_key_here

# API Base URL（可选，不填则使用 OpenAI 官方地址）
# OpenAI 官方：https://api.openai.com/v1
# 第三方兼容服务：填入你的代理地址，如 https://api.example.com/v1
OPENAI_API_BASE_URL=https://api.openai.com/v1

# 聊天模型（可选，默认 gpt-4o-mini）
# 推荐：gpt-4o-mini（便宜快速）、gpt-4o（质量更高）
# 兼容模型：如 qwen-turbo、glm-4-flash 等（需兼容 OpenAI 格式）
CHAT_MODEL=gpt-4o-mini

# 图像模型（可选，默认 dall-e-3）
# 如果你的 API 服务不支持 DALL-E，设为 false 将使用本地图片
IMAGE_MODEL=dall-e-3

# 图片模式
# true  = 使用 AI 生成图片（需要 IMAGE_MODEL 可用）
# false = 使用本地图片文件（放在 public/images/ 目录下）
USE_AI_IMAGES=false

# AI 请求超时时间（毫秒），默认 120000（2分钟）
# DALL-E 3 生图通常需要 15-30 秒，网络慢时可增加此值
AI_TIMEOUT=120000

# Supabase
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Pinata IPFS (optional, for uploading AI-generated images)
# PINATA_API_KEY=your_pinata_api_key
# PINATA_SECRET_KEY=your_pinata_secret_key
