# Alcheme Frontend Environment Variables

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# AlchemeSBT Contract Address (after deployment)
NEXT_PUBLIC_ALCHEME_SBT_ADDRESS=0x0000000000000000000000000000000000000000

# Backend API URL (default: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:30001
